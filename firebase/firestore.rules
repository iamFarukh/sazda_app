rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * User-scoped data: profile doc and every subcollection (zakatCycles, zakatPayments,
     * bookmarks, etc.). Recursive wildcard avoids missing a subcollection in rules —
     * Firestore does not inherit parent read/write to child paths.
     */
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
