<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/widget_card_bg"
    android:padding="16dp">

    <!-- Header row: Title + Next countdown -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today's prayers"
                android:textColor="#003527"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Loading…"
                android:textColor="#66003527"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="end">

            <TextView
                android:id="@+id/widget_next_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Next in"
                android:textColor="#66003527"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#003527"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Subtitle line -->
    <TextView
        android:id="@+id/widget_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text=""
        android:textColor="#003527"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_subtitle2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:text=""
        android:textColor="#88003527"
        android:textSize="11sp" />

    <!-- Spacer (use ImageView since View is not supported in RemoteViews) -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:importantForAccessibility="no" />

    <!-- Row: Fajr -->
    <LinearLayout
        android:id="@+id/widget_row_fajr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="7dp"
        android:paddingBottom="7dp"
        android:paddingLeft="8dp"
        android:paddingRight="8dp">

        <ImageView
            android:id="@+id/widget_icon_fajr"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_widget_fajr"
            android:contentDescription="Fajr" />

        <TextView
            android:id="@+id/widget_name_fajr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Fajr"
            android:textColor="#003527"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/widget_time_fajr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#003527"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divider -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="36dp"
        android:background="@drawable/widget_row_divider"
        android:importantForAccessibility="no" />

    <!-- Row: Dhuhr -->
    <LinearLayout
        android:id="@+id/widget_row_dhuhr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="7dp"
        android:paddingBottom="7dp"
        android:paddingLeft="8dp"
        android:paddingRight="8dp">

        <ImageView
            android:id="@+id/widget_icon_dhuhr"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_widget_sun"
            android:contentDescription="Dhuhr" />

        <TextView
            android:id="@+id/widget_name_dhuhr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Dhuhr"
            android:textColor="#003527"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/widget_time_dhuhr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#003527"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divider -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="36dp"
        android:background="@drawable/widget_row_divider"
        android:importantForAccessibility="no" />

    <!-- Row: Asr -->
    <LinearLayout
        android:id="@+id/widget_row_asr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="7dp"
        android:paddingBottom="7dp"
        android:paddingLeft="8dp"
        android:paddingRight="8dp">

        <ImageView
            android:id="@+id/widget_icon_asr"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_widget_sun"
            android:contentDescription="Asr" />

        <TextView
            android:id="@+id/widget_name_asr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Asr"
            android:textColor="#003527"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/widget_time_asr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#003527"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divider -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="36dp"
        android:background="@drawable/widget_row_divider"
        android:importantForAccessibility="no" />

    <!-- Row: Maghrib -->
    <LinearLayout
        android:id="@+id/widget_row_maghrib"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="7dp"
        android:paddingBottom="7dp"
        android:paddingLeft="8dp"
        android:paddingRight="8dp">

        <ImageView
            android:id="@+id/widget_icon_maghrib"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_widget_maghrib"
            android:contentDescription="Maghrib" />

        <TextView
            android:id="@+id/widget_name_maghrib"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Maghrib"
            android:textColor="#003527"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/widget_time_maghrib"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#003527"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divider -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="36dp"
        android:background="@drawable/widget_row_divider"
        android:importantForAccessibility="no" />

    <!-- Row: Isha -->
    <LinearLayout
        android:id="@+id/widget_row_isha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="7dp"
        android:paddingBottom="7dp"
        android:paddingLeft="8dp"
        android:paddingRight="8dp">

        <ImageView
            android:id="@+id/widget_icon_isha"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_widget_moon"
            android:contentDescription="Isha" />

        <TextView
            android:id="@+id/widget_name_isha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Isha"
            android:textColor="#003527"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/widget_time_isha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#003527"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Bottom branding -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:text="Sazda"
        android:textColor="#40003527"
        android:textSize="10sp" />

</LinearLayout>
