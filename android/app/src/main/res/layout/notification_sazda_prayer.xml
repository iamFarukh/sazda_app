<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:orientation="horizontal"
  android:padding="16dp"
  android:gravity="center_vertical"
  android:background="#FFFFFF">

  <FrameLayout
    android:id="@+id/ntf_icon_frame"
    android:layout_width="40dp"
    android:layout_height="40dp"
    android:background="@drawable/sazda_notif_icon_prayer_bg">

    <ImageView
      android:id="@+id/ntf_icon"
      android:layout_width="22dp"
      android:layout_height="22dp"
      android:layout_gravity="center"
      android:scaleType="fitCenter"
      android:contentDescription="@null" />
  </FrameLayout>

  <LinearLayout
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:layout_marginStart="12dp"
    android:orientation="vertical">

    <TextView
      android:id="@+id/ntf_meta"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:textSize="10sp"
      android:textAllCaps="true"
      android:textColor="#707974"
      android:fontFamily="sans-serif-medium" />

    <TextView
      android:id="@+id/ntf_headline"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:textSize="15sp"
      android:textStyle="bold"
      android:textColor="#003527"
      android:layout_marginTop="3dp" />

    <TextView
      android:id="@+id/ntf_body"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:textSize="13sp"
      android:textColor="#404944"
      android:layout_marginTop="2dp" />
  </LinearLayout>
</LinearLayout>
